# Skylark Executive Intelligence Terminal — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Monday.com ───────────────────────────────────────────────────────────────
MONDAY_API_TOKEN=your_monday_personal_api_token_here
MONDAY_DEALS_BOARD_ID=5030096083
MONDAY_WORKORDER_BOARD_ID=5030096670

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
# Provider: 'gemini' or 'openai'
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=https://api.openai.com/v1

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secure_secret_string

# ─── Cache ────────────────────────────────────────────────────────────────────
# TTL in seconds. Default 300 (5 minutes).
CACHE_TTL=300
ENABLE_CACHE=true

# ─── HTTP Client ──────────────────────────────────────────────────────────────
# Timeout in milliseconds for outbound API requests.
REQUEST_TIMEOUT=30000

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_AI=true
ENABLE_ANALYTICS=true
ENABLE_DEBUG=false

# ─── Logging ──────────────────────────────────────────────────────────────────
# Levels: error | warn | info | debug
LOG_LEVEL=info
