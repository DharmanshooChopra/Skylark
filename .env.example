# Server Configuration
PORT=3000
NODE_ENV=development

# Monday.com Configuration
# Get your Personal API Token from Monday.com -> Profile -> Developers
MONDAY_API_TOKEN=your_monday_personal_api_token_here

# LLM Configuration
# Choose either 'gemini' or 'openai' (default 'gemini')
LLM_PROVIDER=gemini

# Gemini API Key (if using gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Settings (if using openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=https://api.openai.com/v1

# Default Board Configurations (Optional, can be set/mapped in UI)
DEALS_BOARD_ID=
WORK_ORDERS_BOARD_ID=
